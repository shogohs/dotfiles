syntax on
set fenc=utf-8
set nobackup
set noswapfile
set autoread
set hidden
set showcmd
set viminfo=
" cursor
set number
set showmatch
set cursorline
" search
set hlsearch
set ignorecase
set incsearch
set wrapscan
set smartcase
" view
set laststatus=2
set showmatch
" tab/indent
set smartindent
set autoindent
set tabstop=2
set shiftwidth=2
set expandtab